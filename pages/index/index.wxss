.page {
  min-height: 100vh;
  padding: 28rpx 26rpx 60rpx;
  background: #f4f8ff;
  color: #111827;
}

.masthead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 0 24rpx;
  animation: pageIn 360ms ease-out both;
}

.brand-block {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(22, 119, 255, 0.18);
  overflow: hidden;
}

.brand-logo {
  width: 76rpx;
  height: 76rpx;
  display: block;
}

.masthead-copy {
  flex: 1;
  min-width: 0;
}

.title {
  display: block;
  min-width: 0;
  color: #111827;
  font-size: 34rpx;
  font-weight: 850;
  letter-spacing: 0;
  line-height: 1.12;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 650;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.copy-btn {
  flex: 0 0 174rpx;
  margin: 0;
  padding: 0;
  height: 58rpx;
  line-height: 58rpx;
  border: 0;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #1677ff 0%, #0b66e4 100%);
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 22rpx rgba(22, 119, 255, 0.22);
}

.copy-btn:active,
.tool:active,
.quick-row text:active,
.segmented text:active {
  transform: scale(0.98);
}

.copy-btn::after {
  border: 0;
}

.switch-card,
.panel,
.schedule {
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(15, 23, 42, 0.08);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 38rpx rgba(15, 23, 42, 0.07);
  animation: cardIn 420ms ease-out both;
}

.switch-card::before,
.panel::before,
.schedule::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #1677ff, #12c6aa, #dbe6f5);
  opacity: 0.88;
}

.switch-card {
  margin-bottom: 18rpx;
  padding: 22rpx;
}

.section-label {
  display: block;
  margin-bottom: 14rpx;
  color: #64748b;
  font-size: 21rpx;
  font-weight: 800;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 20rpx;
  animation: cardIn 480ms ease-out both;
}

.tool {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70rpx;
  padding: 0 18rpx;
  border: 2rpx solid #dde3ea;
  border-radius: 12rpx;
  background: #ffffff;
  color: #475569;
  font-size: 25rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.04);
  transition: transform 160ms ease, background 160ms ease, color 160ms ease;
}

.tool.active {
  border-color: #1677ff;
  background: linear-gradient(135deg, #1677ff 0%, #0b66e4 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(22, 119, 255, 0.22);
}

.panel,
.schedule {
  margin-top: 20rpx;
  padding: 24rpx;
}

.field {
  display: grid;
  grid-template-columns: 178rpx 1fr 48rpx;
  align-items: center;
  min-height: 82rpx;
  margin-top: 12rpx;
  padding: 0 18rpx;
  border: 2rpx solid #edf1ee;
  border-radius: 12rpx;
  background: #fbfcfb;
  transition: border-color 160ms ease, background 160ms ease;
}

.field:first-child {
  margin-top: 0;
}

.label {
  color: #475569;
  font-size: 25rpx;
  font-weight: 800;
}

.input {
  min-height: 78rpx;
  color: #111827;
  font-size: 32rpx;
  font-weight: 850;
  text-align: right;
}

.input-placeholder {
  color: #94a3b8;
  font-size: 25rpx;
  font-weight: 650;
}

.unit {
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 800;
  text-align: right;
}

.quick-row {
  display: flex;
  gap: 12rpx;
  margin: 14rpx 0 6rpx;
  flex-wrap: wrap;
}

.quick-row text {
  padding: 12rpx 18rpx;
  border: 2rpx solid #e2e8e4;
  border-radius: 12rpx;
  background: #ffffff;
  color: #475569;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 16rpx rgba(15, 23, 42, 0.04);
}

.segmented {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 8rpx;
  border-radius: 12rpx;
  background: #edf2f7;
}

.switch-card .segmented {
  margin-top: 0;
}

.segmented.two {
  grid-template-columns: repeat(2, 1fr);
}

.segmented text {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  border-radius: 8rpx;
  color: #475569;
  font-size: 24rpx;
  font-weight: 850;
  transition: transform 160ms ease, background 160ms ease;
}

.segmented text.active {
  background: #ffffff;
  color: #1677ff;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.08);
}

.result-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.metric {
  min-height: 120rpx;
  padding: 18rpx;
  border: 2rpx solid #e7eee9;
  border-radius: 12rpx;
  background: #f8fafc;
}

.metric text {
  display: block;
}

.metric text:first-child {
  color: #64748b;
  font-size: 22rpx;
  font-weight: 750;
}

.metric text:last-child {
  margin-top: 12rpx;
  color: #111827;
  font-size: 31rpx;
  font-weight: 850;
  word-break: break-all;
}

.metric.main {
  grid-column: 1 / -1;
  min-height: 144rpx;
  border-color: #1677ff;
  background: linear-gradient(135deg, #1677ff 0%, #0b66e4 60%, #12c6aa 145%);
  box-shadow: 0 16rpx 32rpx rgba(22, 119, 255, 0.22);
}

.metric.main text {
  color: #ffffff;
}

.metric.main text:first-child {
  color: #e8f3ff;
}

.metric.main text:last-child {
  font-size: 42rpx;
}

.metric text.negative,
.metric.main text.negative {
  color: #b9462f;
}

.metric.main text.negative {
  color: #ffe0d6;
}

.schedule-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
  color: #111827;
}

.schedule-title {
  font-size: 28rpx;
  font-weight: 850;
}

.schedule-meta {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  flex-wrap: wrap;
}

.schedule-pill,
.schedule-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  white-space: nowrap;
  font-size: 22rpx;
  font-weight: 850;
}

.schedule-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 44rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  white-space: nowrap;
  font-size: 21rpx;
  font-weight: 850;
  line-height: 44rpx;
}

.schedule-pill {
  background: #e8f3ff;
  color: #1677ff;
}

.schedule-count {
  background: #f1f5f9;
  color: #475569;
}

.schedule-action.share {
  width: 76rpx;
  background: #eef6ff;
  color: #1677ff;
}

.schedule-action.export {
  width: 132rpx;
  background: #1677ff;
  color: #ffffff;
}

.schedule-action::after {
  border: 0;
}

.table-scroll {
  width: 100%;
}

.table-inner {
  min-width: 752rpx;
}

.table-head,
.table-row {
  display: grid;
  grid-template-columns: 128rpx 148rpx 148rpx 148rpx 148rpx;
  gap: 4rpx;
  align-items: center;
  min-height: 62rpx;
  border-bottom: 2rpx solid #edf2ef;
}

.table-head text {
  color: #1677ff;
  font-size: 22rpx;
  font-weight: 850;
}

.table-row text {
  color: #334155;
  font-size: 22rpx;
  font-weight: 650;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.table-head text:not(:first-child),
.table-row text:not(:first-child) {
  text-align: right;
}

.table-row:last-child {
  border-bottom: 0;
}

@keyframes pageIn {
  from {
    opacity: 0;
    transform: translateY(12rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes cardIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes lineIn {
  from {
    opacity: 0;
    transform: scaleX(0.4);
  }
  to {
    opacity: 1;
    transform: scaleX(1);
  }
}
