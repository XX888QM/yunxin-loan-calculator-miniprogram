<view class="page">
  <view class="masthead">
    <view class="brand-block">
      <view class="brand-mark">
        <image class="brand-logo" src="/assets/logo.png" mode="aspectFill" />
      </view>
      <view class="masthead-copy">
        <view class="brand-row">
          <text class="title">云鑫真实贷款计算器</text>
        </view>
        <text class="subtitle">车贷房贷月供、利率、明细</text>
      </view>
    </view>
    <button class="copy-btn" bindtap="copySummary">复制结果</button>
  </view>

  <view class="switch-card">
    <text class="section-label">贷款类型</text>
    <view class="segmented two">
      <text wx:for="{{loanTypeList}}" wx:key="value" class="{{loanType == item.value ? 'active' : ''}}" data-value="{{item.value}}" bindtap="setLoanType">{{item.label}}</text>
    </view>
  </view>

  <view class="tool-grid">
    <view wx:for="{{toolList}}" wx:key="value" class="tool {{activeTool == item.value ? 'active' : ''}}" data-tool="{{item.value}}" bindtap="switchTool">{{item.label}}</view>
  </view>

  <view wx:if="{{activeTool == 'payment'}}" class="panel">
    <view class="segmented two">
      <text class="{{paymentForm.inputMode == 'loan' ? 'active' : ''}}" data-form="paymentForm" data-field="inputMode" data-value="loan" bindtap="setFormValue">填贷款额</text>
      <text class="{{paymentForm.inputMode == 'price' ? 'active' : ''}}" data-form="paymentForm" data-field="inputMode" data-value="price" bindtap="setFormValue">{{loanType == 'car' ? '车价−首付' : '房价−首付'}}</text>
    </view>
    <view class="field" wx:if="{{paymentForm.inputMode == 'loan'}}">
      <text class="label">贷款本金</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入贷款金额" type="digit" value="{{paymentForm.principal}}" data-form="paymentForm" data-field="principal" bindinput="onInput" />
      <text class="unit">{{paymentForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <block wx:if="{{paymentForm.inputMode == 'price'}}">
      <view class="field">
        <text class="label">{{loanType == 'car' ? '车价' : '房价'}}</text>
        <input class="input" placeholder-class="input-placeholder" placeholder="落地总价" type="digit" value="{{paymentForm.carPrice}}" data-form="paymentForm" data-field="carPrice" bindinput="onInput" />
        <text class="unit">{{paymentForm.unit == 'wan' ? '万' : '元'}}</text>
      </view>
      <view class="quick-row">
        <text wx:for="{{downRatioOptions}}" wx:key="*this" data-form="paymentForm" data-field="downRatio" data-value="{{item}}" bindtap="setFormValue">首付{{item}}%</text>
      </view>
      <view class="field">
        <text class="label">首付{{paymentForm.downRatio ? paymentForm.downRatio + '%' : '金额'}}</text>
        <input class="input" placeholder-class="input-placeholder" placeholder="自定义首付金额" type="digit" value="{{paymentForm.downPayment}}" data-form="paymentForm" data-field="downPayment" bindinput="onInput" />
        <text class="unit">{{paymentForm.unit == 'wan' ? '万' : '元'}}</text>
      </view>
    </block>
    <view class="segmented two">
      <text class="{{paymentForm.unit == 'yuan' ? 'active' : ''}}" data-form="paymentForm" data-field="unit" data-value="yuan" bindtap="setFormValue">按元</text>
      <text class="{{paymentForm.unit == 'wan' ? 'active' : ''}}" data-form="paymentForm" data-field="unit" data-value="wan" bindtap="setFormValue">按万</text>
    </view>
    <view class="field">
      <text class="label">还款期数</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入还款期数" type="number" value="{{paymentForm.months}}" data-form="paymentForm" data-field="months" bindinput="onInput" />
      <text class="unit">期</text>
    </view>
    <view class="quick-row">
      <text wx:for="{{termOptionList}}" wx:key="value" data-form="paymentForm" data-value="{{item.value}}" bindtap="setMonths">{{item.label}}</text>
    </view>
    <view class="field">
      <text class="label">{{paymentForm.rateMode == 'monthly' ? '月息%' : '年化%'}}</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="{{paymentForm.rateMode == 'monthly' ? '例如 0.59' : '例如 13.14'}}" type="digit" value="{{paymentForm.annualRate}}" data-form="paymentForm" data-field="annualRate" bindinput="onInput" />
      <text class="unit">%</text>
    </view>
    <view class="segmented two">
      <text class="{{paymentForm.rateMode == 'annual' ? 'active' : ''}}" data-form="paymentForm" data-field="rateMode" data-value="annual" bindtap="setFormValue">年化%</text>
      <text class="{{paymentForm.rateMode == 'monthly' ? 'active' : ''}}" data-form="paymentForm" data-field="rateMode" data-value="monthly" bindtap="setFormValue">月息%</text>
    </view>
    <view class="segmented">
      <text class="{{paymentForm.method == 'equalInstallment' ? 'active' : ''}}" data-form="paymentForm" data-field="method" data-value="equalInstallment" bindtap="setFormValue">等额本息</text>
      <text class="{{paymentForm.method == 'equalPrincipal' ? 'active' : ''}}" data-form="paymentForm" data-field="method" data-value="equalPrincipal" bindtap="setFormValue">等额本金</text>
      <text class="{{paymentForm.method == 'interestOnly' ? 'active' : ''}}" data-form="paymentForm" data-field="method" data-value="interestOnly" bindtap="setFormValue">先息后本</text>
    </view>
    <view class="result-grid">
      <view class="metric main"><text>{{paymentResult.primaryLabel}}</text><text>{{paymentResult.primaryPayment}}</text></view>
      <view class="metric" wx:if="{{paymentForm.inputMode == 'price'}}"><text>贷款额</text><text>{{paymentResult.loanAmount}}</text></view>
      <view class="metric"><text>末期还款</text><text>{{paymentResult.lastPayment}}</text></view>
      <view class="metric"><text>总利息</text><text>{{paymentResult.totalInterest}}</text></view>
      <view class="metric"><text>还款总额</text><text>{{paymentResult.totalPayment}}</text></view>
    </view>
  </view>

  <view wx:if="{{activeTool == 'combo'}}" class="panel">
    <view class="field">
      <text class="label">商贷本金</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入商贷金额" type="digit" value="{{comboForm.commercialPrincipal}}" data-form="comboForm" data-field="commercialPrincipal" bindinput="onInput" />
      <text class="unit">{{comboForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="segmented two">
      <text class="{{comboForm.unit == 'yuan' ? 'active' : ''}}" data-form="comboForm" data-field="unit" data-value="yuan" bindtap="setFormValue">按元</text>
      <text class="{{comboForm.unit == 'wan' ? 'active' : ''}}" data-form="comboForm" data-field="unit" data-value="wan" bindtap="setFormValue">按万</text>
    </view>
    <view class="field">
      <text class="label">商贷{{comboForm.rateMode == 'monthly' ? '月息' : '年化'}}</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="{{comboForm.rateMode == 'monthly' ? '例如 0.35' : '例如 3.45'}}" type="digit" value="{{comboForm.commercialRate}}" data-form="comboForm" data-field="commercialRate" bindinput="onInput" />
      <text class="unit">%</text>
    </view>
    <view class="field">
      <text class="label">公积金本金</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入公积金金额" type="digit" value="{{comboForm.fundPrincipal}}" data-form="comboForm" data-field="fundPrincipal" bindinput="onInput" />
      <text class="unit">{{comboForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="field">
      <text class="label">公积金{{comboForm.rateMode == 'monthly' ? '月息' : '年化'}}</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="{{comboForm.rateMode == 'monthly' ? '例如 0.25' : '例如 2.85'}}" type="digit" value="{{comboForm.fundRate}}" data-form="comboForm" data-field="fundRate" bindinput="onInput" />
      <text class="unit">%</text>
    </view>
    <view class="field">
      <text class="label">贷款年限</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入贷款年限" type="number" value="{{comboForm.years}}" data-form="comboForm" data-field="years" bindinput="onInput" />
      <text class="unit">年</text>
    </view>
    <view class="segmented two">
      <text class="{{comboForm.rateMode == 'annual' ? 'active' : ''}}" data-form="comboForm" data-field="rateMode" data-value="annual" bindtap="setFormValue">年化%</text>
      <text class="{{comboForm.rateMode == 'monthly' ? 'active' : ''}}" data-form="comboForm" data-field="rateMode" data-value="monthly" bindtap="setFormValue">月息%</text>
    </view>
    <view class="segmented two">
      <text class="{{comboForm.method == 'equalInstallment' ? 'active' : ''}}" data-form="comboForm" data-field="method" data-value="equalInstallment" bindtap="setFormValue">等额本息</text>
      <text class="{{comboForm.method == 'equalPrincipal' ? 'active' : ''}}" data-form="comboForm" data-field="method" data-value="equalPrincipal" bindtap="setFormValue">等额本金</text>
    </view>
    <view class="result-grid">
      <view class="metric main"><text>首月/每月</text><text>{{comboResult.primaryPayment}}</text></view>
      <view class="metric"><text>末期还款</text><text>{{comboResult.lastPayment}}</text></view>
      <view class="metric"><text>总利息</text><text>{{comboResult.totalInterest}}</text></view>
      <view class="metric"><text>还款总额</text><text>{{comboResult.totalPayment}}</text></view>
    </view>
  </view>

  <view wx:if="{{activeTool == 'budget'}}" class="panel">
    <view class="field">
      <text class="label">月供预算</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="每月能还多少" type="digit" value="{{budgetForm.monthlyBudget}}" data-form="budgetForm" data-field="monthlyBudget" bindinput="onInput" />
      <text class="unit">元</text>
    </view>
    <view class="field">
      <text class="label">还款期数</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入还款期数" type="number" value="{{budgetForm.months}}" data-form="budgetForm" data-field="months" bindinput="onInput" />
      <text class="unit">期</text>
    </view>
    <view class="quick-row">
      <text wx:for="{{termOptionList}}" wx:key="value" data-form="budgetForm" data-value="{{item.value}}" bindtap="setMonths">{{item.label}}</text>
    </view>
    <view class="field">
      <text class="label">{{budgetForm.rateMode == 'monthly' ? '月息%' : '年化%'}}</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="{{budgetForm.rateMode == 'monthly' ? '例如 0.59' : '例如 13.14'}}" type="digit" value="{{budgetForm.annualRate}}" data-form="budgetForm" data-field="annualRate" bindinput="onInput" />
      <text class="unit">%</text>
    </view>
    <view class="segmented two">
      <text class="{{budgetForm.rateMode == 'annual' ? 'active' : ''}}" data-form="budgetForm" data-field="rateMode" data-value="annual" bindtap="setFormValue">年化%</text>
      <text class="{{budgetForm.rateMode == 'monthly' ? 'active' : ''}}" data-form="budgetForm" data-field="rateMode" data-value="monthly" bindtap="setFormValue">月息%</text>
    </view>
    <view class="segmented two">
      <text class="{{budgetForm.method == 'equalInstallment' ? 'active' : ''}}" data-form="budgetForm" data-field="method" data-value="equalInstallment" bindtap="setFormValue">等额本息</text>
      <text class="{{budgetForm.method == 'equalPrincipal' ? 'active' : ''}}" data-form="budgetForm" data-field="method" data-value="equalPrincipal" bindtap="setFormValue">等额本金</text>
    </view>
    <view class="result-grid">
      <view class="metric main"><text>可贷本金</text><text>{{budgetResult.principal}}</text></view>
      <view class="metric"><text>首月/每月</text><text>{{budgetResult.primaryPayment}}</text></view>
      <view class="metric"><text>总利息</text><text>{{budgetResult.totalInterest}}</text></view>
      <view class="metric"><text>还款总额</text><text>{{budgetResult.totalPayment}}</text></view>
    </view>
  </view>

  <view wx:if="{{activeTool == 'actual'}}" class="panel">
    <view class="field">
      <text class="label">贷款本金</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入贷款金额" type="digit" value="{{actualForm.principal}}" data-form="actualForm" data-field="principal" bindinput="onInput" />
      <text class="unit">{{actualForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="segmented two">
      <text class="{{actualForm.unit == 'yuan' ? 'active' : ''}}" data-form="actualForm" data-field="unit" data-value="yuan" bindtap="setFormValue">按元</text>
      <text class="{{actualForm.unit == 'wan' ? 'active' : ''}}" data-form="actualForm" data-field="unit" data-value="wan" bindtap="setFormValue">按万</text>
    </view>
    <view class="segmented two">
      <text class="{{actualForm.inputMode == 'payment' ? 'active' : ''}}" data-form="actualForm" data-field="inputMode" data-value="payment" bindtap="setFormValue">知道月供</text>
      <text class="{{actualForm.inputMode == 'interest' ? 'active' : ''}}" data-form="actualForm" data-field="inputMode" data-value="interest" bindtap="setFormValue">只知总利息</text>
    </view>
    <view class="field" wx:if="{{actualForm.inputMode == 'payment'}}">
      <text class="label">实际月供</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入合同月供" type="digit" value="{{actualForm.monthlyPayment}}" data-form="actualForm" data-field="monthlyPayment" bindinput="onInput" />
      <text class="unit">元</text>
    </view>
    <view class="field" wx:if="{{actualForm.inputMode == 'interest'}}">
      <text class="label">总利息</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="整个贷款多付的利息" type="digit" value="{{actualForm.totalInterest}}" data-form="actualForm" data-field="totalInterest" bindinput="onInput" />
      <text class="unit">{{actualForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="field">
      <text class="label">前置费用</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="GPS费/服务费等，没有留空" type="digit" value="{{actualForm.upfrontFee}}" data-form="actualForm" data-field="upfrontFee" bindinput="onInput" />
      <text class="unit">{{actualForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="field">
      <text class="label">还款期数</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入还款期数" type="number" value="{{actualForm.months}}" data-form="actualForm" data-field="months" bindinput="onInput" />
      <text class="unit">期</text>
    </view>
    <view class="field">
      <text class="label">对外{{actualForm.claimedRateMode == 'monthly' ? '月息%' : '年化%'}}</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="{{actualForm.claimedRateMode == 'monthly' ? '例如 0.59' : '例如 7.08'}}" type="digit" value="{{actualForm.claimedMonthlyRate}}" data-form="actualForm" data-field="claimedMonthlyRate" bindinput="onInput" />
      <text class="unit">%</text>
    </view>
    <view class="segmented two">
      <text class="{{actualForm.claimedRateMode == 'annual' ? 'active' : ''}}" data-form="actualForm" data-field="claimedRateMode" data-value="annual" bindtap="setFormValue">年化%</text>
      <text class="{{actualForm.claimedRateMode == 'monthly' ? 'active' : ''}}" data-form="actualForm" data-field="claimedRateMode" data-value="monthly" bindtap="setFormValue">月息%</text>
    </view>
    <view class="result-grid">
      <view class="metric main"><text>真实月利率</text><text>{{actualResult.monthlyRate}}</text></view>
      <view class="metric"><text>含费月利率</text><text>{{actualResult.feeAdjustedMonthlyRate}}</text></view>
      <view class="metric"><text>名义年化</text><text>{{actualResult.annualNominalRate}}</text></view>
      <view class="metric"><text>复利年化</text><text>{{actualResult.annualEffectiveRate}}</text></view>
      <view class="metric"><text>含费复利年化</text><text>{{actualResult.feeAdjustedAnnualEffectiveRate}}</text></view>
      <view class="metric"><text>口径倍数</text><text>{{actualResult.claimedMultiple}}</text></view>
      <view class="metric"><text>月息差</text><text>{{actualResult.claimedMonthlyGap}}</text></view>
      <view class="metric"><text>总利息</text><text>{{actualResult.totalInterest}}</text></view>
    </view>
  </view>

  <view wx:if="{{activeTool == 'flat'}}" class="panel">
    <view class="field">
      <text class="label">贷款本金</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入贷款金额" type="digit" value="{{flatForm.principal}}" data-form="flatForm" data-field="principal" bindinput="onInput" />
      <text class="unit">{{flatForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="segmented two">
      <text class="{{flatForm.unit == 'yuan' ? 'active' : ''}}" data-form="flatForm" data-field="unit" data-value="yuan" bindtap="setFormValue">按元</text>
      <text class="{{flatForm.unit == 'wan' ? 'active' : ''}}" data-form="flatForm" data-field="unit" data-value="wan" bindtap="setFormValue">按万</text>
    </view>
    <view class="field">
      <text class="label">平息{{flatForm.rateMode == 'annual' ? '年化%' : '月息%'}}</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="{{flatForm.rateMode == 'monthly' ? '例如 0.59' : '例如 7.08'}}" type="digit" value="{{flatForm.monthlyFlatRate}}" data-form="flatForm" data-field="monthlyFlatRate" bindinput="onInput" />
      <text class="unit">%</text>
    </view>
    <view class="field">
      <text class="label">还款期数</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入还款期数" type="number" value="{{flatForm.months}}" data-form="flatForm" data-field="months" bindinput="onInput" />
      <text class="unit">期</text>
    </view>
    <view class="segmented two">
      <text class="{{flatForm.rateMode == 'annual' ? 'active' : ''}}" data-form="flatForm" data-field="rateMode" data-value="annual" bindtap="setFormValue">年化%</text>
      <text class="{{flatForm.rateMode == 'monthly' ? 'active' : ''}}" data-form="flatForm" data-field="rateMode" data-value="monthly" bindtap="setFormValue">月息%</text>
    </view>
    <view class="result-grid">
      <view class="metric main"><text>平息月供</text><text>{{flatResult.monthlyPayment}}</text></view>
      <view class="metric"><text>真实月利率</text><text>{{flatResult.actualMonthlyRate}}</text></view>
      <view class="metric"><text>真实年化</text><text>{{flatResult.actualAnnualEffectiveRate}}</text></view>
      <view class="metric"><text>总利息</text><text>{{flatResult.totalInterest}}</text></view>
    </view>
  </view>

  <view wx:if="{{activeTool == 'balloon'}}" class="panel">
    <view class="field">
      <text class="label">贷款本金</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入贷款金额" type="digit" value="{{balloonForm.principal}}" data-form="balloonForm" data-field="principal" bindinput="onInput" />
      <text class="unit">{{balloonForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="segmented two">
      <text class="{{balloonForm.unit == 'yuan' ? 'active' : ''}}" data-form="balloonForm" data-field="unit" data-value="yuan" bindtap="setFormValue">按元</text>
      <text class="{{balloonForm.unit == 'wan' ? 'active' : ''}}" data-form="balloonForm" data-field="unit" data-value="wan" bindtap="setFormValue">按万</text>
    </view>
    <view class="field">
      <text class="label">还款期数</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入还款期数" type="number" value="{{balloonForm.months}}" data-form="balloonForm" data-field="months" bindinput="onInput" />
      <text class="unit">期</text>
    </view>
    <view class="quick-row">
      <text wx:for="{{termOptionList}}" wx:key="value" data-form="balloonForm" data-value="{{item.value}}" bindtap="setMonths">{{item.label}}</text>
    </view>
    <view class="field">
      <text class="label">{{balloonForm.rateMode == 'monthly' ? '月息%' : '年化%'}}</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="{{balloonForm.rateMode == 'monthly' ? '例如 0.59' : '例如 13.14'}}" type="digit" value="{{balloonForm.annualRate}}" data-form="balloonForm" data-field="annualRate" bindinput="onInput" />
      <text class="unit">%</text>
    </view>
    <view class="segmented two">
      <text class="{{balloonForm.rateMode == 'annual' ? 'active' : ''}}" data-form="balloonForm" data-field="rateMode" data-value="annual" bindtap="setFormValue">年化%</text>
      <text class="{{balloonForm.rateMode == 'monthly' ? 'active' : ''}}" data-form="balloonForm" data-field="rateMode" data-value="monthly" bindtap="setFormValue">月息%</text>
    </view>
    <view class="quick-row">
      <text wx:for="{{balloonRatioOptions}}" wx:key="*this" data-form="balloonForm" data-field="balloonRatio" data-value="{{item}}" bindtap="setFormValue">尾款{{item}}%</text>
    </view>
    <view class="field">
      <text class="label">尾款{{balloonForm.balloonRatio ? balloonForm.balloonRatio + '%' : '金额'}}</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="自定义尾款金额" type="digit" value="{{balloonForm.balloonAmount}}" data-form="balloonForm" data-field="balloonAmount" bindinput="onInput" />
      <text class="unit">{{balloonForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="result-grid">
      <view class="metric main"><text>月供</text><text>{{balloonResult.monthlyPayment}}</text></view>
      <view class="metric"><text>末期还款(含尾款)</text><text>{{balloonResult.lastPayment}}</text></view>
      <view class="metric"><text>总利息</text><text>{{balloonResult.totalInterest}}</text></view>
      <view class="metric"><text>还款总额</text><text>{{balloonResult.totalPayment}}</text></view>
      <view class="metric"><text>等额本息月供</text><text>{{balloonResult.normalMonthly}}</text></view>
      <view class="metric"><text>等额本息总利息</text><text>{{balloonResult.normalInterest}}</text></view>
    </view>
  </view>

  <view wx:if="{{activeTool == 'rto'}}" class="panel">
    <view class="segmented two">
      <text class="{{rtoForm.mode == 'analyze' ? 'active' : ''}}" data-form="rtoForm" data-field="mode" data-value="analyze" bindtap="setFormValue">方案测算</text>
      <text class="{{rtoForm.mode == 'pricing' ? 'active' : ''}}" data-form="rtoForm" data-field="mode" data-value="pricing" bindtap="setFormValue">定价反推</text>
    </view>
    <view class="field">
      <text class="label">车价{{rtoForm.mode == 'analyze' ? '(选填)' : ''}}</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="{{rtoForm.mode == 'analyze' ? '填了才算隐含年化' : '车辆成本价'}}" type="digit" value="{{rtoForm.carPrice}}" data-form="rtoForm" data-field="carPrice" bindinput="onInput" />
      <text class="unit">{{rtoForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="segmented two">
      <text class="{{rtoForm.unit == 'yuan' ? 'active' : ''}}" data-form="rtoForm" data-field="unit" data-value="yuan" bindtap="setFormValue">按元</text>
      <text class="{{rtoForm.unit == 'wan' ? 'active' : ''}}" data-form="rtoForm" data-field="unit" data-value="wan" bindtap="setFormValue">按万</text>
    </view>
    <view class="field">
      <text class="label">首付/保证金</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="没有填0或留空" type="digit" value="{{rtoForm.downPayment}}" data-form="rtoForm" data-field="downPayment" bindinput="onInput" />
      <text class="unit">{{rtoForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="field" wx:if="{{rtoForm.mode == 'analyze'}}">
      <text class="label">月租金</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="每月租金" type="digit" value="{{rtoForm.monthlyRent}}" data-form="rtoForm" data-field="monthlyRent" bindinput="onInput" />
      <text class="unit">元</text>
    </view>
    <view class="field">
      <text class="label">租期</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="多少期" type="number" value="{{rtoForm.months}}" data-form="rtoForm" data-field="months" bindinput="onInput" />
      <text class="unit">期</text>
    </view>
    <view class="quick-row">
      <text wx:for="{{termOptionList}}" wx:key="value" data-form="rtoForm" data-value="{{item.value}}" bindtap="setMonths">{{item.label}}</text>
    </view>
    <view class="field">
      <text class="label">期满尾款</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="期满过户尾款，没有填0" type="digit" value="{{rtoForm.buyout}}" data-form="rtoForm" data-field="buyout" bindinput="onInput" />
      <text class="unit">{{rtoForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="field" wx:if="{{rtoForm.mode == 'analyze'}}">
      <text class="label">对比年化(选填)</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="填了对比普通车贷" type="digit" value="{{rtoForm.bankAnnualRate}}" data-form="rtoForm" data-field="bankAnnualRate" bindinput="onInput" />
      <text class="unit">%</text>
    </view>
    <view class="field" wx:if="{{rtoForm.mode == 'pricing'}}">
      <text class="label">参考年化</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="用于反推月租" type="digit" value="{{rtoForm.targetAnnualRate}}" data-form="rtoForm" data-field="targetAnnualRate" bindinput="onInput" />
      <text class="unit">%</text>
    </view>
    <view class="result-grid" wx:if="{{rtoResult.mode == 'analyze'}}">
      <view class="metric main"><text>总费用</text><text>{{rtoResult.totalCost}}</text></view>
      <view class="metric"><text>比全款多花</text><text>{{rtoResult.premiumOverCash}}</text></view>
      <view class="metric"><text>隐含月利率</text><text>{{rtoResult.impliedMonthlyRate}}</text></view>
      <view class="metric"><text>隐含复利年化</text><text>{{rtoResult.impliedAnnualEffectiveRate}}</text></view>
      <view class="metric" wx:if="{{rtoResult.bankCompare}}"><text>比普通车贷多花</text><text>{{rtoResult.bankCompare}}</text></view>
    </view>
    <view class="result-grid" wx:if="{{rtoResult.mode == 'pricing'}}">
      <view class="metric main"><text>月租定价</text><text>{{rtoResult.monthlyRent}}</text></view>
      <view class="metric"><text>客户总费用</text><text>{{rtoResult.totalCost}}</text></view>
      <view class="metric"><text>比全款多花</text><text>{{rtoResult.premiumOverCash}}</text></view>
    </view>
  </view>

  <view wx:if="{{activeTool == 'prepay'}}" class="panel">
    <view class="field">
      <text class="label">贷款本金</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入贷款金额" type="digit" value="{{prepayForm.principal}}" data-form="prepayForm" data-field="principal" bindinput="onInput" />
      <text class="unit">{{prepayForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="segmented two">
      <text class="{{prepayForm.unit == 'yuan' ? 'active' : ''}}" data-form="prepayForm" data-field="unit" data-value="yuan" bindtap="setFormValue">按元</text>
      <text class="{{prepayForm.unit == 'wan' ? 'active' : ''}}" data-form="prepayForm" data-field="unit" data-value="wan" bindtap="setFormValue">按万</text>
    </view>
    <view class="field">
      <text class="label">{{prepayForm.rateMode == 'monthly' ? '月息%' : '年化%'}}</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="{{prepayForm.rateMode == 'monthly' ? '例如 0.59' : '例如 13.14'}}" type="digit" value="{{prepayForm.annualRate}}" data-form="prepayForm" data-field="annualRate" bindinput="onInput" />
      <text class="unit">%</text>
    </view>
    <view class="field">
      <text class="label">总期数</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="输入总期数" type="number" value="{{prepayForm.months}}" data-form="prepayForm" data-field="months" bindinput="onInput" />
      <text class="unit">期</text>
    </view>
    <view class="field">
      <text class="label">已还期数</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="已还多少期" type="number" value="{{prepayForm.paidMonths}}" data-form="prepayForm" data-field="paidMonths" bindinput="onInput" />
      <text class="unit">期</text>
    </view>
    <view class="field">
      <text class="label">提前还款</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="准备提前还多少" type="digit" value="{{prepayForm.prepayAmount}}" data-form="prepayForm" data-field="prepayAmount" bindinput="onInput" />
      <text class="unit">{{prepayForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="segmented two">
      <text class="{{prepayForm.rateMode == 'annual' ? 'active' : ''}}" data-form="prepayForm" data-field="rateMode" data-value="annual" bindtap="setFormValue">年化%</text>
      <text class="{{prepayForm.rateMode == 'monthly' ? 'active' : ''}}" data-form="prepayForm" data-field="rateMode" data-value="monthly" bindtap="setFormValue">月息%</text>
    </view>
    <view class="segmented two">
      <text class="{{prepayForm.penaltyMode == 'percent' ? 'active' : ''}}" data-form="prepayForm" data-field="penaltyMode" data-value="percent" bindtap="setFormValue">违约金%</text>
      <text class="{{prepayForm.penaltyMode == 'amount' ? 'active' : ''}}" data-form="prepayForm" data-field="penaltyMode" data-value="amount" bindtap="setFormValue">违约金额</text>
    </view>
    <view class="field" wx:if="{{prepayForm.penaltyMode == 'percent'}}">
      <text class="label">违约金比例</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="按提前还款额收，常见2~3，没有留空" type="digit" value="{{prepayForm.penaltyPercent}}" data-form="prepayForm" data-field="penaltyPercent" bindinput="onInput" />
      <text class="unit">%</text>
    </view>
    <view class="field" wx:if="{{prepayForm.penaltyMode == 'amount'}}">
      <text class="label">违约金额</text>
      <input class="input" placeholder-class="input-placeholder" placeholder="固定违约金" type="digit" value="{{prepayForm.penaltyAmount}}" data-form="prepayForm" data-field="penaltyAmount" bindinput="onInput" />
      <text class="unit">{{prepayForm.unit == 'wan' ? '万' : '元'}}</text>
    </view>
    <view class="segmented two">
      <text class="{{prepayForm.reduceMode == 'term' ? 'active' : ''}}" data-form="prepayForm" data-field="reduceMode" data-value="term" bindtap="setFormValue">缩短期限</text>
      <text class="{{prepayForm.reduceMode == 'payment' ? 'active' : ''}}" data-form="prepayForm" data-field="reduceMode" data-value="payment" bindtap="setFormValue">降低月供</text>
    </view>
    <view class="result-grid">
      <view class="metric"><text>当前剩余本金</text><text>{{prepayResult.remainingBalance}}</text></view>
      <view class="metric"><text>还后本金</text><text>{{prepayResult.afterPrepayBalance}}</text></view>
      <view class="metric"><text>预计省利息</text><text>{{prepayResult.interestSaved}}</text></view>
      <view class="metric"><text>违约金</text><text>{{prepayResult.penalty}}</text></view>
      <view class="metric main"><text>净省(扣违约金)</text><text class="{{prepayResult.netSavedNegative ? 'negative' : ''}}">{{prepayResult.netSaved}}</text></view>
      <view class="metric"><text>新剩余期数</text><text>{{prepayResult.newRemainingMonths}}期</text></view>
      <view class="metric"><text>原月供</text><text>{{prepayResult.oldMonthlyPayment}}</text></view>
      <view class="metric"><text>新月供</text><text>{{prepayResult.newMonthlyPayment}}</text></view>
    </view>
  </view>

  <view class="schedule" wx:if="{{activeSchedulePreview.length}}">
    <view class="schedule-head">
      <text class="schedule-title">还款明细</text>
      <view class="schedule-meta">
        <picker mode="date" fields="month" value="{{scheduleStartYm}}" bindchange="setScheduleStart">
          <text class="schedule-pill">{{scheduleStartYm ? '首期 ' + scheduleStartYm : '设首期年月'}}</text>
        </picker>
        <text class="schedule-count">共 {{activeSchedulePreview.length}} 期</text>
        <button wx:if="{{!pdfShareUnlocked}}" class="schedule-export" bindtap="openPdfSharePanel">导出PDF</button>
        <button wx:else class="schedule-export" bindtap="exportSchedulePdf">导出PDF</button>
      </view>
    </view>
    <scroll-view class="table-scroll" scroll-x>
      <view class="table-inner">
        <view class="table-head">
          <text>月份</text><text>还款</text><text>本金</text><text>利息</text><text>余额</text>
        </view>
        <view class="table-row" wx:for="{{activeSchedulePreview}}" wx:key="month">
          <text>{{item.label}}</text>
          <text>{{item.payment}}</text>
          <text>{{item.principal}}</text>
          <text>{{item.interest}}</text>
          <text>{{item.balance}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{showPdfSharePanel}}" class="share-mask" bindtap="closePdfSharePanel">
    <view class="share-panel" catchtap="noop">
      <text class="share-title">分享后导出PDF</text>
      <text class="share-desc">选择一种分享方式，分享后即可导出还款明细。</text>
      <button class="share-option primary" open-type="share">发给朋友</button>
      <button class="share-option" bindtap="showTimelineShareTip">发朋友圈</button>
      <button class="share-cancel" bindtap="closePdfSharePanel">取消</button>
    </view>
  </view>
</view>
